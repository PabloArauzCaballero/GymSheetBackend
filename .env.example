NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_sheet
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_LOGGING=false

JWT_ACCESS_SECRET=replace_this_with_a_minimum_32_character_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_this_with_a_minimum_32_character_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
GATEWAY_ENABLED=true
