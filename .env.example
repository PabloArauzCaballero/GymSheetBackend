NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY=false
REQUEST_BODY_LIMIT=1mb
LOG_LEVEL=info
BUSINESS_TIME_ZONE=America/La_Paz
ACCESS_POLICY_VERSION=2026-07-19
ACCESS_MOCK_ENABLED=true
# Optional. When set (min. 32 chars), GET /health/metrics requires
# `Authorization: Bearer <token>`. Leave empty to keep the endpoint open and
# restrict it at network level instead.
METRICS_SCRAPE_TOKEN=

# Shared rate-limit counters. Without this, limits are per-process and the
# effective limit multiplies by the number of instances. Required for any
# horizontally scaled deployment.
REDIS_URL=
# Set true in multi-instance deployments to fail startup when REDIS_URL is absent
# instead of silently degrading to per-process rate limiting.
REDIS_REQUIRED=false
REDIS_CONNECT_TIMEOUT_MS=5000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_sheet
DB_USER=gym_sheet_writer
DB_PASSWORD=replace_with_runtime_secret
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000
DB_CONNECT_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=15000

JWT_ACCESS_SECRET=replace_with_at_least_64_random_characters_from_a_secret_manager
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_64_character_secret_from_a_secret_manager
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=gym-sheet-api
JWT_AUDIENCE=gym-sheet-web

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
GATEWAY_ENABLED=true

WORKER_POLL_INTERVAL_MS=1000
WORKER_BATCH_SIZE=50
WORKER_CONCURRENCY=5
WORKER_LOCK_TIMEOUT_MS=300000
WORKER_MAX_ATTEMPTS=5
REMINDER_SCAN_INTERVAL_MS=3600000
NOTIFICATION_DELIVERY_PROVIDER=IN_APP
NOTIFICATION_GATEWAY_URL=
NOTIFICATION_GATEWAY_SECRET=
NOTIFICATION_GATEWAY_ALLOWED_HOSTS=
NOTIFICATION_GATEWAY_TIMEOUT_MS=10000

EXERCISES_DATASET_ENABLED=false
EXERCISES_DATASET_JSON_URL=https://raw.githubusercontent.com/hasaneyldrm/exercises-dataset/main/data/exercises.json
EXERCISES_DATASET_ALLOWED_HOSTS=raw.githubusercontent.com
EXERCISES_DATASET_TIMEOUT_MS=15000
EXERCISES_DATASET_MAX_RESPONSE_BYTES=15728640
EXERCISES_DATASET_BATCH_SIZE=100
EXERCISES_DATASET_IMPORT_MEDIA=false
EXERCISES_DATASET_MEDIA_LICENSE_CONFIRMED=false
