    "@nestjs/sequelize": "^10.0.1",
    "@nestjs/throttler": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "dotenv": "^16.4.7",
    "helmet": "^7.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
