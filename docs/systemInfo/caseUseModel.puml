@startuml
left to right direction

actor "Cliente / Usuario del gym" as Cliente
actor "Administrador del gym" as Admin
actor "Entrenador externo" as Entrenador

rectangle "App Web de Entrenamiento" {

  usecase "Iniciar sesión" as UC1
  usecase "Registrar perfil básico\nedad, peso, estatura, objetivo" as UC2

  usecase "Ver ejercicios predeterminados" as UC3
  usecase "Seleccionar ejercicios frecuentes" as UC4
  usecase "Crear ejercicio personalizado\nsegún máquinas disponibles" as UC5
  usecase "Ver máquinas e indumentaria\ndisponible del gym" as UC6

  usecase "Iniciar sesión de entrenamiento" as UC7
  usecase "Agregar ejercicio a la sesión" as UC8
  usecase "Registrar serie" as UC9
  usecase "Editar serie registrada" as UC10
  usecase "Finalizar entrenamiento" as UC11
  usecase "Consultar historial de entrenamiento" as UC12
  usecase "Exportar información para entrenador externo" as UC13

  usecase "Gestionar máquinas e indumentaria" as UC14
  usecase "Crear ejercicios predeterminados" as UC15
  usecase "Editar ejercicios predeterminados" as UC16
  usecase "Inhabilitar ejercicios predeterminados" as UC17
}

Cliente --> UC1
Cliente --> UC2
Cliente --> UC3
Cliente --> UC4
Cliente --> UC5
Cliente --> UC6
Cliente --> UC7
Cliente --> UC8
Cliente --> UC9
Cliente --> UC10
Cliente --> UC11
Cliente --> UC12
Cliente --> UC13

Admin --> UC14
Admin --> UC15
Admin --> UC16
Admin --> UC17

Entrenador --> UC13

UC5 ..> UC6 : <<include>>
UC8 ..> UC3 : <<include>>
UC8 ..> UC5 : <<extend>>
UC13 ..> UC6 : <<include>>
UC13 ..> UC12 : <<include>>

@enduml